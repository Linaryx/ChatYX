{
  "name": "chatyx",
  "version": "3.0.0",
  "private": true,
  "description": "Modern Twitch and YouTube chat overlay with multi-platform emote support",
  "type": "module",
  "workspaces": ["services/*"],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:pages": "vite build && bun scripts/prepare-github-pages.ts",
    "start": "vite preview --host",
    "youtube:dev": "bun run --cwd services/youtube-websocket dev",
    "youtube:start": "bun run --cwd services/youtube-websocket start",
    "lint": "bun run lint:app && bun run lint:youtube",
    "lint:app": "oxlint -c ./.oxlintrc.json --tsconfig ./tsconfig.app.json src",
    "lint:youtube": "oxlint -c ./.oxlintrc.json services/youtube-websocket/src",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && bun run --cwd services/youtube-websocket typecheck",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "csstype": "^3.2.3",
    "oxlint": "^1.73.0",
    "typescript": "6.0.2",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.12",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "lucid-color-picker": "^0.1.0",
    "solid-js": "^1.9.14"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
